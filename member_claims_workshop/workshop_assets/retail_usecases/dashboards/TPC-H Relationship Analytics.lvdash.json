{
  "datasets": [
    {
      "name": "938353a9",
      "displayName": "Revenue by Region",
      "queryLines": [
        "SELECT\n",
        "  r.r_name AS region,\n",
        "  ROUND(SUM(l.l_extendedprice * (1 - l.l_discount)), 2) AS revenue,\n",
        "  COUNT(DISTINCT o.o_orderkey) AS total_orders\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.lineitem l\n",
        "    JOIN aira_test.aibi_workshop_schema.orders o\n",
        "      ON l.l_orderkey = o.o_orderkey\n",
        "    JOIN aira_test.aibi_workshop_schema.customer c\n",
        "      ON o.o_custkey = c.c_custkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON c.c_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  r.r_name\n",
        "ORDER BY\n",
        "  revenue DESC"
      ]
    },
    {
      "name": "3fdae0c1",
      "displayName": "Revenue by Nation",
      "queryLines": [
        "SELECT\n",
        "  n.n_name AS nation,\n",
        "  r.r_name AS region,\n",
        "  ROUND(SUM(l.l_extendedprice * (1 - l.l_discount)), 2) AS revenue,\n",
        "  COUNT(DISTINCT o.o_orderkey) AS total_orders,\n",
        "  COUNT(DISTINCT c.c_custkey) AS total_customers\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.lineitem l\n",
        "    JOIN aira_test.aibi_workshop_schema.orders o\n",
        "      ON l.l_orderkey = o.o_orderkey\n",
        "    JOIN aira_test.aibi_workshop_schema.customer c\n",
        "      ON o.o_custkey = c.c_custkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON c.c_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  n.n_name,\n",
        "  r.r_name\n",
        "ORDER BY\n",
        "  revenue DESC"
      ]
    },
    {
      "name": "2c2dc5fe",
      "displayName": "Top Customers",
      "queryLines": [
        "SELECT\n",
        "  c.c_name AS customer_name,\n",
        "  n.n_name AS nation,\n",
        "  r.r_name AS region,\n",
        "  c.c_mktsegment AS market_segment,\n",
        "  ROUND(SUM(l.l_extendedprice * (1 - l.l_discount)), 2) AS revenue,\n",
        "  COUNT(DISTINCT o.o_orderkey) AS total_orders\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.lineitem l\n",
        "    JOIN aira_test.aibi_workshop_schema.orders o\n",
        "      ON l.l_orderkey = o.o_orderkey\n",
        "    JOIN aira_test.aibi_workshop_schema.customer c\n",
        "      ON o.o_custkey = c.c_custkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON c.c_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  c.c_name,\n",
        "  n.n_name,\n",
        "  r.r_name,\n",
        "  c.c_mktsegment\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 50"
      ]
    },
    {
      "name": "6682dc2c",
      "displayName": "Top Suppliers",
      "queryLines": [
        "SELECT\n",
        "  s.s_name AS supplier_name,\n",
        "  n.n_name AS nation,\n",
        "  r.r_name AS region,\n",
        "  ROUND(SUM(l.l_extendedprice * (1 - l.l_discount)), 2) AS revenue,\n",
        "  COUNT(DISTINCT l.l_orderkey) AS orders_supplied\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.lineitem l\n",
        "    JOIN aira_test.aibi_workshop_schema.supplier s\n",
        "      ON l.l_suppkey = s.s_suppkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON s.s_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  s.s_name,\n",
        "  n.n_name,\n",
        "  r.r_name\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 50"
      ]
    },
    {
      "name": "4edd05bd",
      "displayName": "Orders by Status",
      "queryLines": [
        "SELECT\n",
        "  o.o_orderstatus AS order_status,\n",
        "  o.o_orderpriority AS priority,\n",
        "  r.r_name AS region,\n",
        "  n.n_name AS nation,\n",
        "  c.c_mktsegment AS market_segment,\n",
        "  COUNT(*) AS order_count,\n",
        "  ROUND(SUM(o.o_totalprice), 2) AS total_value,\n",
        "  ROUND(AVG(o.o_totalprice), 2) AS avg_order_value\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.orders o\n",
        "    JOIN aira_test.aibi_workshop_schema.customer c\n",
        "      ON o.o_custkey = c.c_custkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON c.c_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  o.o_orderstatus,\n",
        "  o.o_orderpriority,\n",
        "  r.r_name,\n",
        "  n.n_name,\n",
        "  c.c_mktsegment\n",
        "ORDER BY\n",
        "  order_count DESC"
      ]
    },
    {
      "name": "70ca5c2d",
      "displayName": "Monthly Order Trends",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('month', o.o_orderdate) AS order_month,\n",
        "  r.r_name AS region,\n",
        "  n.n_name AS nation,\n",
        "  COUNT(*) AS order_count,\n",
        "  ROUND(SUM(o.o_totalprice), 2) AS total_revenue,\n",
        "  COUNT(DISTINCT o.o_custkey) AS unique_customers\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.orders o\n",
        "    JOIN aira_test.aibi_workshop_schema.customer c\n",
        "      ON o.o_custkey = c.c_custkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON c.c_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  DATE_TRUNC('month', o.o_orderdate),\n",
        "  r.r_name,\n",
        "  n.n_name\n",
        "ORDER BY\n",
        "  order_month"
      ]
    },
    {
      "name": "2cdbe31f",
      "displayName": "Parts by Supplier Region",
      "queryLines": [
        "SELECT\n",
        "  r.r_name AS region,\n",
        "  p.p_type AS part_type,\n",
        "  COUNT(DISTINCT ps.ps_partkey) AS part_count,\n",
        "  COUNT(DISTINCT ps.ps_suppkey) AS supplier_count,\n",
        "  ROUND(AVG(ps.ps_supplycost), 2) AS avg_supply_cost\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.partsupp ps\n",
        "    JOIN aira_test.aibi_workshop_schema.part p\n",
        "      ON ps.ps_partkey = p.p_partkey\n",
        "    JOIN aira_test.aibi_workshop_schema.supplier s\n",
        "      ON ps.ps_suppkey = s.s_suppkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON s.s_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  r.r_name,\n",
        "  p.p_type\n",
        "ORDER BY\n",
        "  part_count DESC"
      ]
    },
    {
      "name": "fb29eac7",
      "displayName": "Shipping Analysis",
      "queryLines": [
        "SELECT\n",
        "  l.l_shipmode AS ship_mode,\n",
        "  l.l_shipinstruct AS ship_instruction,\n",
        "  r.r_name AS region,\n",
        "  n.n_name AS nation,\n",
        "  COUNT(*) AS line_items,\n",
        "  ROUND(SUM(l.l_extendedprice * (1 - l.l_discount)), 2) AS revenue,\n",
        "  ROUND(AVG(DATEDIFF(l.l_receiptdate, l.l_shipdate)), 1) AS avg_delivery_days\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.lineitem l\n",
        "    JOIN aira_test.aibi_workshop_schema.orders o\n",
        "      ON l.l_orderkey = o.o_orderkey\n",
        "    JOIN aira_test.aibi_workshop_schema.customer c\n",
        "      ON o.o_custkey = c.c_custkey\n",
        "    JOIN aira_test.aibi_workshop_schema.nation n\n",
        "      ON c.c_nationkey = n.n_nationkey\n",
        "    JOIN aira_test.aibi_workshop_schema.region r\n",
        "      ON n.n_regionkey = r.r_regionkey\n",
        "GROUP BY\n",
        "  l.l_shipmode,\n",
        "  l.l_shipinstruct,\n",
        "  r.r_name,\n",
        "  n.n_name\n",
        "ORDER BY\n",
        "  revenue DESC"
      ]
    }
  ],
