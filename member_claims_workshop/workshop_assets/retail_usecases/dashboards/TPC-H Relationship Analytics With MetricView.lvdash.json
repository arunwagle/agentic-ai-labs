{
  "datasets": [
    {
      "name": "d3193914",
      "displayName": "Revenue by Nation",
      "queryLines": [
        "SELECT\n",
        "  customer_nation AS `Customer Nation`,\n",
        "  customer_region AS `Customer Region`,\n",
        "  MEASURE(revenue) AS revenue\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  customer_nation,\n",
        "  customer_region\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 25"
      ]
    },
    {
      "name": "629984df",
      "displayName": "Orders by Status",
      "queryLines": [
        "SELECT\n",
        "  order_status,\n",
        "  order_priority AS priority,\n",
        "  customer_region AS region,\n",
        "  customer_nation AS nation,\n",
        "  market_segment,\n",
        "  MEASURE(order_count) AS order_count\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  order_status,\n",
        "  order_priority,\n",
        "  customer_region,\n",
        "  customer_nation,\n",
        "  market_segment\n",
        "ORDER BY\n",
        "  order_count DESC"
      ]
    },
    {
      "name": "6351314c",
      "displayName": "Top Customers",
      "queryLines": [
        "SELECT\n",
        "  customer_name,\n",
        "  customer_nation AS nation,\n",
        "  customer_region AS region,\n",
        "  market_segment,\n",
        "  MEASURE(revenue) AS revenue,\n",
        "  MEASURE(order_count) AS total_orders\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  customer_name,\n",
        "  customer_nation,\n",
        "  customer_region,\n",
        "  market_segment\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 50"
      ]
    },
    {
      "name": "822495aa",
      "displayName": "Revenue by Region",
      "queryLines": [
        "SELECT\n",
        "  customer_region AS `Customer Region`,\n",
        "  MEASURE(revenue) AS revenue\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  customer_region\n",
        "ORDER BY\n",
        "  revenue DESC"
      ]
    },
    {
      "name": "ee3989b3",
      "displayName": "Top Suppliers",
      "queryLines": [
        "SELECT\n",
        "  supplier_name,\n",
        "  supplier_nation AS nation,\n",
        "  supplier_region AS region,\n",
        "  MEASURE(revenue) AS revenue,\n",
        "  MEASURE(order_count) AS orders_supplied\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  supplier_name,\n",
        "  supplier_nation,\n",
        "  supplier_region\n",
        "ORDER BY\n",
        "  revenue DESC\n",
        "LIMIT 50"
      ]
    },
    {
      "name": "8765f587",
      "displayName": "Parts by Supplier Region",
      "queryLines": [
        "SELECT\n",
        "  supplier_region AS region,\n",
        "  supplier_nation AS nation,\n",
        "  MEASURE(line_item_count) AS part_count,\n",
        "  MEASURE(revenue) AS revenue\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  supplier_region,\n",
        "  supplier_nation\n",
        "ORDER BY\n",
        "  part_count DESC"
      ]
    },
    {
      "name": "f5e921f1",
      "displayName": "Shipping Analysis",
      "queryLines": [
        "SELECT\n",
        "  ship_mode,\n",
        "  ship_instruction,\n",
        "  customer_region AS region,\n",
        "  customer_nation AS nation,\n",
        "  MEASURE(revenue) AS revenue,\n",
        "  MEASURE(avg_delivery_days) AS avg_delivery_days\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  ship_mode,\n",
        "  ship_instruction,\n",
        "  customer_region,\n",
        "  customer_nation\n",
        "ORDER BY\n",
        "  revenue DESC"
      ]
    },
    {
      "name": "8129e8ff",
      "displayName": "Monthly Order Trends",
      "queryLines": [
        "SELECT\n",
        "  order_month,\n",
        "  customer_region AS region,\n",
        "  customer_nation AS nation,\n",
        "  MEASURE(revenue) AS total_revenue,\n",
        "  MEASURE(order_count) AS order_count\n",
        "FROM\n",
        "  aira_test.aibi_workshop_schema.order_management_metrics\n",
        "GROUP BY\n",
        "  order_month,\n",
        "  customer_region,\n",
        "  customer_nation\n",
        "ORDER BY\n",
        "  order_month"
      ]
    },
