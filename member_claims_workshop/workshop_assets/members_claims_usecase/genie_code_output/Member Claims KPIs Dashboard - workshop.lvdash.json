{
  "datasets": [
    {
      "name": "ds_kpi_summary",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT MEASURE(total_claims) AS total_claims, MEASURE(total_paid) AS total_paid, MEASURE(pmpm) AS pmpm, MEASURE(unique_members) AS unique_members, MEASURE(member_months) AS member_months, MEASURE(avg_paid_per_claim) AS avg_paid_per_claim, MEASURE(denial_rate) AS denial_rate, MEASURE(clean_claim_rate) AS clean_claim_rate FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop"
      ]
    },
    {
      "name": "ds_monthly_trends",
      "displayName": "Monthly Trends",
      "queryLines": [
        "SELECT service_month, line_of_business, claim_type, MEASURE(total_paid) AS total_paid, MEASURE(total_claims) AS total_claims, MEASURE(pmpm) AS pmpm, MEASURE(unique_members) AS unique_members, MEASURE(denial_rate) AS denial_rate, MEASURE(clean_claim_rate) AS clean_claim_rate, MEASURE(avg_paid_per_claim) AS avg_paid_per_claim FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY service_month, line_of_business, claim_type ORDER BY service_month"
      ]
    },
    {
      "name": "ds_window_measures",
      "displayName": "Window Measures",
      "queryLines": [
        "SELECT service_month, MEASURE(rolling_3m_pmpm) AS rolling_3m_pmpm, MEASURE(pmpm) AS pmpm, MEASURE(current_month_members) AS current_members, MEASURE(previous_month_members) AS prior_members, MEASURE(mom_active_member_growth) AS mom_growth FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY service_month ORDER BY service_month"
      ]
    },
    {
      "name": "ds_by_lob",
      "displayName": "By Line of Business",
      "queryLines": [
        "SELECT line_of_business, MEASURE(total_paid) AS total_paid, MEASURE(total_claims) AS total_claims, MEASURE(pmpm) AS pmpm, MEASURE(unique_members) AS unique_members FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY line_of_business ORDER BY total_paid DESC"
      ]
    },
    {
      "name": "ds_demographics",
      "displayName": "Demographics",
      "queryLines": [
        "SELECT member_age_group, member_sex, member_state, line_of_business, MEASURE(unique_members) AS unique_members, MEASURE(total_paid) AS total_paid, MEASURE(avg_paid_per_member) AS avg_paid_per_member FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY member_age_group, member_sex, member_state, line_of_business"
      ]
    },
    {
      "name": "ds_claims_analysis",
      "displayName": "Claims Analysis",
      "queryLines": [
        "SELECT service_month, line_status, line_of_business, claim_type, MEASURE(total_claim_lines) AS total_lines, MEASURE(total_paid) AS total_paid, MEASURE(denial_rate) AS denial_rate, MEASURE(clean_claim_rate) AS clean_claim_rate, MEASURE(payment_to_billed_ratio) AS pay_to_billed, MEASURE(payment_to_allowed_ratio) AS pay_to_allowed FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY service_month, line_status, line_of_business, claim_type ORDER BY service_month"
      ]
    }
  ],
