{
  "datasets": [
    {
      "name": "ds_utilization",
      "displayName": "Utilization Data",
      "queryLines": [
        "SELECT service_month, line_of_business, claim_type, place_of_service, MEASURE(total_claims) AS total_claims, MEASURE(total_claim_lines) AS total_lines, MEASURE(total_paid) AS total_paid, MEASURE(inpatient_paid) AS inpatient_paid, MEASURE(outpatient_paid) AS outpatient_paid, MEASURE(claims_per_1000_members) AS claims_per_1000, MEASURE(claims_per_member) AS claims_per_member, MEASURE(lines_per_claim) AS lines_per_claim FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY service_month, line_of_business, claim_type, place_of_service ORDER BY service_month"
      ]
    },
    {
      "name": "ds_provider",
      "displayName": "Provider Data",
      "queryLines": [
        "SELECT provider_specialty, par_provider_indicator, rendering_provider, line_of_business, MEASURE(total_paid) AS total_paid, MEASURE(total_claims) AS total_claims, MEASURE(avg_paid_per_claim) AS avg_per_claim, MEASURE(par_provider_rate) AS par_rate, MEASURE(unique_members) AS unique_members FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY provider_specialty, par_provider_indicator, rendering_provider, line_of_business"
      ]
    },
    {
      "name": "ds_operational",
      "displayName": "Operational Metrics",
      "queryLines": [
        "SELECT service_month, adjudication_status, line_status, line_of_business, claim_type, MEASURE(total_claim_lines) AS total_lines, MEASURE(total_paid) AS total_paid, MEASURE(denial_rate) AS denial_rate, MEASURE(payment_to_billed_ratio) AS pay_to_billed, MEASURE(payment_to_allowed_ratio) AS pay_to_allowed, MEASURE(par_provider_rate) AS par_rate FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop GROUP BY service_month, adjudication_status, line_status, line_of_business, claim_type ORDER BY service_month"
      ]
    },
    {
      "name": "ds_summary2",
      "displayName": "Summary KPIs",
      "queryLines": [
        "SELECT MEASURE(total_claims) AS total_claims, MEASURE(total_claim_lines) AS total_lines, MEASURE(inpatient_paid) AS inpatient_paid, MEASURE(outpatient_paid) AS outpatient_paid, MEASURE(par_provider_rate) AS par_rate, MEASURE(claims_per_1000_members) AS claims_per_1000 FROM aira_test.aibi_workshop_mv_schema.member_claims_metric_view_workshop"
      ]
    }
  ],
