{
  "datasets": [
    {
      "name": "dashboards_created",
      "displayName": "Dashboards Created",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as dashboards_created\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name = 'createDashboard'\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:user_filter), 0) = 0\n",
        "    OR array_contains(:user_filter, user_identity.email)\n",
        "  )"
      ],
      "parameters": [
        {
          "displayName": "User Email",
          "keyword": "user_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        }
      ]
    },
    {
      "name": "total_views",
      "displayName": "Total Dashboard Views",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as total_views\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name IN ('getDashboard', 'getPublishedDashboard')\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:user_filter), 0) = 0\n",
        "    OR array_contains(:user_filter, user_identity.email)\n",
        "  )\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:dashboard_filter), 0) = 0\n",
        "    OR array_contains(:dashboard_filter, request_params.dashboard_id)\n",
        "  )"
      ],
      "parameters": [
        {
          "displayName": "User Email",
          "keyword": "user_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        },
        {
          "displayName": "Dashboard ID",
          "keyword": "dashboard_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        }
      ]
    },
    {
      "name": "popular_dashboards",
      "displayName": "Most Popular Dashboards",
      "queryLines": [
        "SELECT\n",
        "  request_params.dashboard_id as dashboard_id,\n",
        "  COUNT(*) AS view_count\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name IN ('getDashboard', 'getPublishedDashboard')\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:user_filter), 0) = 0\n",
        "    OR array_contains(:user_filter, user_identity.email)\n",
        "  )\n",
        "GROUP BY\n",
        "  dashboard_id\n",
        "ORDER BY\n",
        "  view_count DESC\n",
        "LIMIT 15"
      ],
      "parameters": [
        {
          "displayName": "User Email",
          "keyword": "user_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        }
      ]
    },
    {
      "name": "dashboards_published",
      "displayName": "Dashboards Published",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as dashboards_published\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name = 'publishDashboard'\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:user_filter), 0) = 0\n",
        "    OR array_contains(:user_filter, user_identity.email)\n",
        "  )\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:dashboard_filter), 0) = 0\n",
        "    OR array_contains(:dashboard_filter, request_params.dashboard_id)\n",
        "  )"
      ],
      "parameters": [
        {
          "displayName": "User Email",
          "keyword": "user_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        },
        {
          "displayName": "Dashboard ID",
          "keyword": "dashboard_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        }
      ]
    },
    {
      "name": "daily_activity_trend",
      "displayName": "Daily Activity Trend",
      "queryLines": [
        "SELECT\n",
        "  event_date,\n",
        "  CASE\n",
        "    WHEN action_name IN ('getDashboard', 'getPublishedDashboard') THEN 'Views'\n",
        "    WHEN action_name = 'createDashboard' THEN 'Created'\n",
        "    WHEN action_name = 'updateDashboard' THEN 'Updated'\n",
        "    WHEN action_name = 'publishDashboard' THEN 'Published'\n",
        "    ELSE 'Other'\n",
        "  END as action_category,\n",
        "  COUNT(*) as event_count\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  service_name = 'dashboards'\n",
        "  AND action_name IN (\n",
        "    'getDashboard',\n",
        "    'getPublishedDashboard',\n",
        "    'createDashboard',\n",
        "    'updateDashboard',\n",
        "    'publishDashboard'\n",
        "  )\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:user_filter), 0) = 0\n",
        "    OR array_contains(:user_filter, user_identity.email)\n",
        "  )\n",
        "GROUP BY\n",
        "  event_date,\n",
        "  action_category\n",
        "ORDER BY\n",
        "  event_date"
      ],
      "parameters": [
        {
          "displayName": "User Email",
          "keyword": "user_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        }
      ]
    },
    {
      "name": "top_viewers",
      "displayName": "Top Dashboard Viewers",
      "queryLines": [
        "SELECT\n",
        "  user_identity.email as user_email,\n",
        "  COUNT(*) as view_count\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name IN ('getDashboard', 'getPublishedDashboard')\n",
        "  AND event_date >= current_date() - INTERVAL 7 days\n",
        "GROUP BY\n",
        "  user_email\n",
        "ORDER BY\n",
        "  view_count DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "recent_deletions",
      "displayName": "Recent Dashboard Deletions",
      "queryLines": [
        "SELECT\n",
        "  event_time,\n",
        "  user_identity.email as user_email,\n",
        "  request_params.dashboard_id as dashboard_id,\n",
        "  action_name\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name IN ('trashDashboard', 'deleteDashboard')\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "ORDER BY\n",
        "  event_time DESC\n",
        "LIMIT 50"
      ]
    },
    {
      "name": "views_by_user",
      "displayName": "Views by User Draft vs Published",
      "queryLines": [
        "SELECT\n",
        "  user_identity.email as user_email,\n",
        "  action_name,\n",
        "  COUNT(*) as view_count\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  service_name = 'dashboards'\n",
        "  AND action_name IN ('getDashboard', 'getPublishedDashboard')\n",
        "  AND event_date >= current_date() - INTERVAL 7 days\n",
        "GROUP BY\n",
        "  user_email,\n",
        "  action_name\n",
        "ORDER BY\n",
        "  view_count DESC"
      ]
    },
    {
      "name": "top_creators",
      "displayName": "Top Dashboard Creators",
      "queryLines": [
        "SELECT\n",
        "  user_identity.email as user_email,\n",
        "  COUNT(*) as dashboards_created\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  action_name = 'createDashboard'\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "GROUP BY\n",
        "  user_email\n",
        "ORDER BY\n",
        "  dashboards_created DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "actions_summary",
      "displayName": "Dashboard Actions Summary",
      "queryLines": [
        "SELECT\n",
        "  action_name,\n",
        "  COUNT(*) as event_count,\n",
        "  COUNT(DISTINCT user_identity.email) as unique_users,\n",
        "  MIN(event_date) as first_seen,\n",
        "  MAX(event_date) as last_seen\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  service_name = 'dashboards'\n",
        "  AND event_date >= current_date() - INTERVAL 30 days\n",
        "  AND (\n",
        "    COALESCE(CARDINALITY(:user_filter), 0) = 0\n",
        "    OR array_contains(:user_filter, user_identity.email)\n",
        "  )\n",
        "GROUP BY\n",
        "  action_name\n",
        "ORDER BY\n",
        "  event_count DESC"
      ],
      "parameters": [
        {
          "displayName": "User Email",
          "keyword": "user_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING"
            }
          }
        }
      ]
    },
    {
      "name": "filter_users",
      "displayName": "Filter Values - Users",
      "queryLines": [
        "SELECT DISTINCT\n",
        "  user_identity.email as user_email\n",
        "FROM\n",
        "  system.access.audit\n",
        "WHERE\n",
        "  service_name = 'dashboards'\n",
        "  AND event_date >= current_date() - INTERVAL 90 days\n",
        "  AND user_identity.email IS NOT NULL\n",
        "  AND user_identity.email != 'System-User'\n",
        "ORDER BY\n",
        "  user_email"
      ]
    }
  ],
