    {
      "name": "global_filters",
      "displayName": "Global Filters",
      "layout": [
        {
          "widget": {
            "name": "user_filter",
            "queries": [
              {
                "name": "dashboards/01f12f6c90721606a966be455cc3eb01/datasets/01f12f6eca231c54a031f0c6537ebe4e_user_email",
                "query": {
                  "datasetName": "filter_users",
                  "fields": [
                    {
                      "name": "user_email",
                      "expression": "`user_email`"
                    },
                    {
                      "name": "user_email_associativity",
                      "expression": "COUNT_IF(`associative_filter_predicate_group`)"
                    }
                  ],
                  "disaggregated": false
                }
              },
              {
